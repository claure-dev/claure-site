---
import Layout from './Layout.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags?: string[];
  readTime?: number;
}

const { title, description, pubDate, tags = [], readTime } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — claure.org`} description={description}>
  <div class="reading-progress" id="reading-progress"></div>
  <main>
    <div class="container" style="padding-top: 3rem; padding-bottom: 4rem;">
      <div style="max-width: 720px; margin: 0 auto;">
        <div style="margin-bottom: 2rem;">
          <a href="/blog" style="color: var(--text2); font-size: 0.9rem;">← All posts</a>
        </div>

        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 1rem;">
          {tags.map(tag => <a href={`/blog/tag/${tag}`} class="badge badge-blue" style="text-decoration: none;">{tag}</a>)}
        </div>

        <h1 style="font-size: 2.2rem; margin: 0 0 1rem;">{title}</h1>
        <p style="color: var(--text2); margin: 0 0 2rem; font-size: 1.05rem;">{description}</p>

        <div style="display: flex; gap: 1rem; color: var(--text2); font-size: 0.85rem; padding-bottom: 2rem; border-bottom: 1px solid var(--border); margin-bottom: 2rem;">
          <span>{formattedDate}</span>
          {readTime && <span>{readTime} min read</span>}
        </div>

        <div class="prose">
          <slot />
        </div>

        <div style="margin-top: 4rem; padding-top: 2rem; border-top: 1px solid var(--border);">
          <h3 style="margin: 0 0 0.5rem;">Stay in the loop</h3>
          <p style="color: var(--text2); margin: 0 0 1rem; font-size: 0.9rem;">
            New posts on homelab automation, AI-assisted infrastructure, and self-hosting. No spam.
          </p>
          <!-- Buttondown embed placeholder -->
          <form
            action="https://buttondown.com/api/emails/embed-subscribe/claure"
            method="post"
            class="newsletter-form"
          >
            <input type="email" name="email" placeholder="your@email.com" required />
            <button type="submit" class="btn btn-primary">Subscribe</button>
          </form>
        </div>
      </div>
    </div>
  </main>

  <script>
    const bar = document.getElementById('reading-progress');
    if (bar) {
      window.addEventListener('scroll', () => {
        const h = document.documentElement.scrollHeight - window.innerHeight;
        bar.style.width = h > 0 ? `${(window.scrollY / h) * 100}%` : '0%';
      });
    }
  </script>

  <style>
    .reading-progress {
      position: fixed;
      top: 0;
      left: 0;
      height: 2px;
      background: var(--accent);
      width: 0%;
      z-index: 200;
      transition: width 50ms;
    }
  </style>
</Layout>
