---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "FrontBot",
    description: "Always-on homelab operator. Monitors infrastructure, triages email across 10 accounts, delivers daily briefs, and remediates issues autonomously. Reviews dev sessions, proposes next work, maintains continuity across ephemeral Claude Code sessions.",
    tags: ["Python", "Claude", "Matrix", "SQLite"],
    status: "Production",
    github: "https://github.com/claure-lab/frontbot",
    stats: "400+ tests, 20+ providers, runs 24/7",
  },
  {
    title: "Content Forge",
    description: "AI video pipeline for YouTube Shorts. Script generation, voice cloning via Chatterbox TTS, image generation via Flux/Pollinations, depth-based parallax effects, automated subtitles, FFmpeg assembly. Web workbench for iterating on runs.",
    tags: ["Python", "FastAPI", "React", "FFmpeg", "ComfyUI"],
    status: "Active dev",
    github: "https://github.com/claure-lab/content-forge",
    stats: "Script to video in ~60s on RTX 3080",
  },
  {
    title: "Homelab Infrastructure",
    description: "Proxmox hypervisor running 3 VMs, 17+ Docker containers. Nginx Proxy Manager, AdGuard, Uptime Kuma, Jellyfin media stack, Synapse Matrix server. All deployed via Ansible, backed up to Backblaze B2.",
    tags: ["Proxmox", "Docker", "Ansible", "Linux"],
    status: "Production",
    github: "https://github.com/claure-lab/homelab-ansible",
    stats: "3 VMs, automated snapshots + offsite backup",
  },
  {
    title: "claure.org",
    description: "This site. Astro 6 with terminal-aesthetic dark theme, self-hosted behind NPM.",
    tags: ["Astro", "TypeScript", "MDX"],
    status: "Live",
    github: "https://github.com/claure-dev/claure-site",
  },
];
---

<Layout
  title="Projects — claure.org"
  description="What I'm building: homelab automation, AI video pipeline, and an autonomous sysadmin bot."
>
  <main>
    <section style="padding: 4rem 0 2rem;">
      <div class="container">
        <div class="section-header">
          <h1 style="font-size: 2.5rem; margin: 0 0 0.5rem;">Projects</h1>
          <p>Self-hosted, AI-assisted, and probably over-engineered.</p>
        </div>

        <div style="display: flex; flex-direction: column; gap: 2rem;">
          {projects.map(project => (
            <div class="card" style="padding: 2rem;">
              <div style="display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
                <div>
                  <h2 style="margin: 0 0 0.5rem; font-size: 1.5rem;">{project.title}</h2>
                  <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    {project.tags.map(tag => (
                      <span class="badge badge-blue" style="font-size: 0.7rem;">{tag}</span>
                    ))}
                  </div>
                </div>
                <span class="badge badge-green">{project.status}</span>
              </div>
              <p style="color: var(--text2); margin: 0 0 1rem;">{project.description}</p>
              <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                {project.github && (
                  <a href={project.github} style="font-size: 0.85rem;">GitHub &rarr;</a>
                )}
                {project.stats && (
                  <span style="font-size: 0.8rem; color: var(--text2); font-family: var(--font-mono);">
                    {project.stats}
                  </span>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
