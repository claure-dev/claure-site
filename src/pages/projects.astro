---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: "FrontBot",
    description: "Always-on homelab manager. Monitors infrastructure, triages email across 10 accounts, delivers a morning brief, and remediates issues autonomously. Modular Python, Claude-powered synthesis, Matrix for command/control.",
    tags: ["Python", "Claude", "Matrix", "Automation"],
    status: "Running in production",
  },
  {
    title: "Content Forge",
    description: "AI video pipeline that generates YouTube Shorts on local GPU. Voice cloning via Chatterbox TTS, image generation via Flux, FFmpeg assembly with effects and subtitles. Workbench UI for iterating on runs.",
    tags: ["Python", "FastAPI", "React", "FFmpeg", "ComfyUI"],
    status: "Active development",
  },
  {
    title: "Homelab Infrastructure",
    description: "Proxmox hypervisor running 3 VMs, 17+ Docker containers. Nginx Proxy Manager, AdGuard, Uptime Kuma, Jellyfin media stack, Synapse Matrix server. All deployed via Ansible, backed up to Backblaze B2.",
    tags: ["Proxmox", "Docker", "Ansible", "Linux"],
    status: "Running in production",
  },
];
---

<Layout
  title="Projects — claure.org"
  description="What I'm building: homelab automation, AI video pipeline, and an autonomous sysadmin bot."
>
  <main>
    <section style="padding: 4rem 0 2rem;">
      <div class="container">
        <div class="section-header">
          <h1 style="font-size: 2.5rem; margin: 0 0 0.5rem;">Projects</h1>
          <p>Things I'm building and running. All self-hosted, all AI-assisted.</p>
        </div>

        <div style="display: flex; flex-direction: column; gap: 2rem;">
          {projects.map(project => (
            <div class="card" style="padding: 2rem;">
              <div style="display: flex; align-items: flex-start; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1rem;">
                <div>
                  <h2 style="margin: 0 0 0.5rem; font-size: 1.5rem;">{project.title}</h2>
                  <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    {project.tags.map(tag => (
                      <span class="badge badge-blue" style="font-size: 0.7rem;">{tag}</span>
                    ))}
                  </div>
                </div>
                <span class="badge badge-green">{project.status}</span>
              </div>
              <p style="color: var(--text2); margin: 0;">{project.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>
