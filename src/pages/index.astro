---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="claure.org"
  description="Adam's homelab and AI projects."
>
  <section style="padding: 5rem 0 3rem;">
    <div class="container">
      <div style="max-width: 600px;">
        <h1 style="font-size: 2.5rem; margin: 0 0 1rem; line-height: 1.2;">
          ~/claure.org
        </h1>
        <p style="font-size: 1.1rem; color: var(--text2); margin: 0 0 2rem;">
          I run a homelab and build things with AI. This is where I write about it.
        </p>
        <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
          <a href="/blog" class="btn btn-primary">Blog</a>
          <a href="/projects" class="btn btn-outline">Projects</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
